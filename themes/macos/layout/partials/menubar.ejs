<%
var appName = theme.finder_name || 'Finder';
if (page.layout === 'post') appName = 'TextEdit';
else if (page.layout !== 'index' && page.title) appName = page.title;
var isDesktop = page.layout === 'index';
var blogTitle = config.title || 'Blog';

// Menu definitions. action: nav | lock | close | min | zoom | welcome | fullscreen | copy | selectall | noop
var menus = [
  { id: 'apple', apple: true, items: [
    { label: 'About This Blog', action: 'nav', url: '/about/' },
    { sep: true },
    { label: 'Lock Screen', action: 'lock', desktopOnly: true },
    { sep: true },
    { label: 'Made with Hexo', action: 'noop', muted: true }
  ]},
  { id: 'app', label: appName, bold: true, items: [
    { label: 'About ' + appName, action: 'nav', url: '/about/' },
    { sep: true },
    { label: 'Quit ' + appName, action: 'close' }
  ]},
  { id: 'file', label: 'File', items: [
    { label: 'Open Welcome.txt', action: 'welcome', desktopOnly: true },
    { label: 'Close Window', action: 'close' }
  ]},
  { id: 'edit', label: 'Edit', items: [
    { label: 'Copy', action: 'copy' },
    { label: 'Select All', action: 'selectall' }
  ]},
  { id: 'view', label: 'View', items: [
    { label: 'Toggle Full Screen', action: 'zoom' },
    { label: 'Enter Full Screen', action: 'fullscreen' }
  ]},
  { id: 'go', label: 'Go', items: [
    { label: 'Blog', action: 'nav', url: '/' },
    { label: 'Archives', action: 'nav', url: '/archives/' },
    { label: 'Readings', action: 'nav', url: '/readings/' },
    { label: 'Projects', action: 'nav', url: '/projects/' },
    { label: 'Publications', action: 'nav', url: '/publications/' },
    { label: 'Links', action: 'nav', url: '/links/' },
    { label: 'About', action: 'nav', url: '/about/' }
  ]},
  { id: 'window', label: 'Window', items: [
    { label: 'Minimize', action: 'min' },
    { label: 'Zoom', action: 'zoom' }
  ]},
  { id: 'help', label: 'Help', items: [
    { label: 'Blog Help', action: 'nav', url: '/about/' },
    { sep: true },
    { label: 'Hello, ' + (theme.user_name || 'there'), action: 'noop', muted: true }
  ]}
];
%>
<header class="menubar glass">
  <div class="menubar-left">
    <% menus.forEach(function(m){ %>
      <div class="menu-root" data-menu="<%= m.id %>">
        <% if (m.apple) { %>
          <span class="menu-apple menu-trigger" title="Apple menu">
            <svg viewBox="0 0 384 512" width="11" height="14" fill="currentColor"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
          </span>
        <% } else { %>
          <span class="menu-trigger <%= m.bold ? 'menu-app' : 'menu-label' %>"><%= m.label %></span>
        <% } %>
        <div class="menu-dropdown glass" hidden>
          <% m.items.forEach(function(it){ %>
            <% if (it.sep) { %>
              <div class="menu-sep"></div>
            <% } else if (!(it.desktopOnly && !isDesktop)) { %>
              <button class="menu-item<%= it.muted ? ' muted' : '' %>" data-action="<%= it.action %>"<% if (it.url) { %> data-url="<%= it.url %>"<% } %>><%= it.label %></button>
            <% } %>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>
  <div class="menubar-right">
    <button class="menu-icon" id="spotlight-btn" title="Search" aria-label="Search">
      <svg viewBox="0 0 512 512" width="13" height="13" fill="currentColor"><path d="M416 208c0 45.9-14.9 88.3-40 122.7L502.6 457.4c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L330.7 376c-34.4 25.2-76.8 40-122.7 40C93.1 416 0 322.9 0 208S93.1 0 208 0S416 93.1 416 208zM208 352a144 144 0 1 0 0-288 144 144 0 1 0 0 288z"/></svg>
    </button>
    <div class="menu-root" data-menu="wifi">
      <span class="menu-icon menu-trigger" title="Wi-Fi">
        <svg viewBox="0 0 640 512" width="16" height="13" fill="currentColor"><path d="M54.2 202.9C123.2 136.7 216.8 96 320 96s196.8 40.7 265.8 106.9c12.8 12.2 33 11.8 45.2-.9s11.8-33-.9-45.2C549.7 79.5 440.4 32 320 32S90.3 79.5 9.8 156.7C-2.9 169-3.3 189.2 8.9 202s32.5 13.2 45.2 .9zM320 256c35.3 0 67.4 14.1 90.9 36.9c12.5 12.1 32.8 11.6 45.1-1.1s11.9-32.9-.4-45.4C421 213.4 372.4 192 320 192s-101 21.4-135.5 54.5c-12.3 12.5-12.7 32.7-.4 45.4s32.6 13.2 45.1 1.1C252.6 270.1 284.7 256 320 256zm80 96a32 32 0 1 0 -64 0 32 32 0 1 0 64 0z"/></svg>
      </span>
      <div class="menu-panel glass" hidden>
        <div class="panel-title">Wi-Fi</div>
        <div class="panel-row"><span class="panel-label">Network</span><span class="panel-value"><%= blogTitle %></span></div>
        <div class="panel-row"><span class="panel-label">Status</span><span class="panel-value panel-ok">Connected</span></div>
        <div class="panel-row"><span class="panel-label">Signal</span><span class="panel-value">Excellent</span></div>
      </div>
    </div>
    <div class="menu-root" data-menu="battery">
      <span class="menu-icon menu-trigger" title="Battery">
        <svg viewBox="0 0 576 512" width="17" height="15" fill="currentColor"><path d="M464 160c8.8 0 16 7.2 16 16V336c0 8.8-7.2 16-16 16H80c-8.8 0-16-7.2-16-16V176c0-8.8 7.2-16 16-16H464zM80 96C35.8 96 0 131.8 0 176V336c0 44.2 35.8 80 80 80H464c44.2 0 80-35.8 80-80V320c17.7 0 32-14.3 32-32V224c0-17.7-14.3-32-32-32V176c0-44.2-35.8-80-80-80H80zm272 96H96V320H352V192z"/></svg>
      </span>
      <div class="menu-panel glass" hidden>
        <div class="panel-title">Battery</div>
        <div class="panel-row"><span class="panel-label">Charge</span><span class="panel-value panel-ok">100%</span></div>
        <div class="panel-row"><span class="panel-label">Source</span><span class="panel-value">Power Adapter</span></div>
        <div class="panel-row"><span class="panel-label">Condition</span><span class="panel-value">Normal</span></div>
      </div>
    </div>
    <div class="menu-root" data-menu="clock">
      <span class="menu-clock menu-trigger" id="menu-clock" title="Date &amp; Time"></span>
      <div class="menu-panel glass panel-calendar" hidden>
        <div class="panel-title" id="cal-title"></div>
        <div class="cal-grid" id="cal-grid"></div>
      </div>
    </div>
  </div>
</header>
<div class="spotlight glass" id="spotlight" hidden>
  <div class="spotlight-box">
    <input type="text" id="spotlight-input" placeholder="Spotlight Search" autocomplete="off">
    <ul class="spotlight-results" id="spotlight-results"></ul>
  </div>
</div>
