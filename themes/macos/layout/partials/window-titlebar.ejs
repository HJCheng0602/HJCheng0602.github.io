<div class="window-titlebar">
  <div class="traffic-lights">
    <button class="tl tl-close" data-win="close" title="Close" aria-label="Close"></button>
    <button class="tl tl-min" data-win="min" title="Minimize" aria-label="Minimize"></button>
    <button class="tl tl-max" data-win="max" title="Full Screen" aria-label="Full Screen"></button>
  </div>
  <div class="window-title"><%= typeof winTitle !== 'undefined' ? winTitle : '' %></div>
  <div class="window-titlebar-spacer"></div>
</div>
